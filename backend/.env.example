NODE_ENV=production

# Server (Render sets PORT automatically)
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://oriasc-api.oriasc.org

# Generate NEW secrets for production:
# node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
ADMIN_JWT_SECRET=replace_me
API_TOKEN_SALT=replace_me
TRANSFER_TOKEN_SALT=replace_me
ENCRYPTION_KEY=replace_me
APP_KEYS=replace_me_1,replace_me_2,replace_me_3,replace_me_4
JWT_SECRET=replace_me

# CORS — frontend origin(s), comma-separated
CORS_ORIGIN=https://oriasc.org,https://www.oriasc.org
FRONTEND_URL=https://oriasc.org

# PostgreSQL — single connection string (Supabase: use Session pooler URI from Dashboard → Connect)
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Supabase session pooler ~15 conn max — keep pool small; one Strapi instance only
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=4

# Payment redirects
PAYMENT_SUCCESS_URL=https://oriasc.org/donate?payment=success
PAYMENT_CANCEL_URL=https://oriasc.org/donate?payment=cancelled
PAYMENT_CALLBACK_URL=https://oriasc.org/donate?payment=success

# Payment providers (server-only)
STRIPE_SECRET_KEY=sk_live_your_key_here
CHAPA_SECRET_KEY=CHASECK-your_key_here
