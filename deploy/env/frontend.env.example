# Copy to frontend/.env.production on VPS — chmod 600

NODE_ENV=production

NEXT_PUBLIC_SITE_URL=https://oriasc.org
NEXT_PUBLIC_STRAPI_URL=https://cms.oriasc.org

# Optional: read-only Strapi API token (server-side routes only — do not use NEXT_PUBLIC_)
# STRAPI_API_TOKEN=

# Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
NEXT_PUBLIC_CHAPA_PUBLIC_KEY=CHAPUBK-your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
CHAPA_SECRET_KEY=CHASECK-your_key_here
PAYMENT_SUCCESS_URL=https://oriasc.org/donate?payment=success
PAYMENT_CANCEL_URL=https://oriasc.org/donate?payment=cancelled

# HRMS on same VPS (system.oriasc.org — do not modify /var/www/hrms)
HRMS_API_BASE_URL=http://127.0.0.1:4000/api/v1
HRMS_WEB_BASE_URL=https://system.oriasc.org
HRMS_FRONTEND_URL=https://system.oriasc.org
