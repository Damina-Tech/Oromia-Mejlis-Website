# Copy to backend/.env on VPS — chmod 600
# Generate secrets: bash deploy/scripts/generate-secrets.sh

NODE_ENV=production
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://cms.oriasc.org
IS_BEHIND_PROXY=true

# openssl rand -base64 32 (run 5 times for keys below)
APP_KEYS=replace_me_1,replace_me_2,replace_me_3,replace_me_4
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
ENCRYPTION_KEY=replace_me
JWT_SECRET=replace_me

CORS_ORIGIN=https://oriasc.org,https://www.oriasc.org
FRONTEND_URL=https://oriasc.org

# Local Docker Postgres (deploy/docker-compose.yml — port 5433)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_NAME=strapi_cms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=replace_with_strong_password
DATABASE_SSL=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10

# Payment redirects (public site)
PAYMENT_SUCCESS_URL=https://oriasc.org/donate?payment=success
PAYMENT_CANCEL_URL=https://oriasc.org/donate?payment=cancelled
PAYMENT_CALLBACK_URL=https://oriasc.org/donate?payment=success

STRIPE_SECRET_KEY=sk_live_your_key_here
CHAPA_SECRET_KEY=CHASECK-your_key_here
